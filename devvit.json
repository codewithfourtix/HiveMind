{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tryhivemind",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Hive Mind: New daily round",
        "description": "Post today's Hive Mind prompt",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Hive Mind: Seed demo answers (dev)",
        "description": "Populate this post with sample answers",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scripts": {
    "build": "npm run build",
    "dev": "npm run build"
  },
  "dev": {
    "subreddit": "tryhivemind_dev"
  }
}